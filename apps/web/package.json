{
  "name": "@leagueos/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --test components/addGameLogic.test.ts",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:all": "playwright test -c playwright.config.ts",
    "test:e2e:global-admin": "playwright test -c playwright.config.ts e2e/global-admin",
    "test:e2e:league-admin": "playwright test -c playwright.config.ts e2e/league-admin",
    "test:e2e:player": "playwright test -c playwright.config.ts e2e/player",
    "test:e2e:tournaments": "playwright test -c playwright.tournaments.config.ts"
  },
  "dependencies": {
    "@leagueos/api": "workspace:*",
    "@leagueos/config": "workspace:*",
    "@leagueos/schemas": "workspace:*",
    "@leagueos/ui": "workspace:*",
    "next": "15.5.12",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.2"
  }
}
